# ============================================================================
# .htaccess principale - Gestione Chiavi
# ============================================================================

# Abilita RewriteEngine
<IfModule mod_rewrite.c>
    RewriteEngine On
</IfModule>

# Index default
DirectoryIndex login.php

# Disabilita directory listing
Options -Indexes

# Blocca accesso a file sensibili
<FilesMatch "\.(sql|log|ini|sh|bak)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>

# Security headers (solo se modulo disponibile)
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set X-XSS-Protection "1; mode=block"
</IfModule>

# Error pages personalizzate
ErrorDocument 403 /error/403.php
ErrorDocument 404 /error/404.php
ErrorDocument 500 /error/500.php
