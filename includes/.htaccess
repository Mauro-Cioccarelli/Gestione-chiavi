# ============================================================================
# Protezione cartella includes - NESSUN accesso diretto
# ============================================================================

<IfModule mod_authz_core.c>
    Require all denied
</IfModule>

<IfModule !mod_authz_core.c>
    Order deny,allow
    Deny from all
</IfModule>

# Eccezione: nessun file in questa cartella deve essere accessibile via browser
# Tutti i file devono essere inclusi solo tramite script PHP
